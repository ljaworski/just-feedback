{
  "name": "@codelionapps/react-native",
  "version": "0.1.0",
  "description": "React Native SDK for just-feedback: drop-in feedback modal, zero native code, Expo-compatible",
  "license": "MIT",
  "keywords": [
    "react-native",
    "expo",
    "feedback",
    "sdk",
    "self-hosted"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ljaworski/just-feedback.git",
    "directory": "packages/sdk-react-native"
  },
  "homepage": "https://github.com/ljaworski/just-feedback#readme",
  "bugs": {
    "url": "https://github.com/ljaworski/just-feedback/issues"
  },
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('lib',{recursive:true,force:true})\"",
    "build": "npm run clean && bob build",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "devDependencies": {
    "@react-native/metro-config": "^0.76.9",
    "@types/react": "^18",
    "react": "^18",
    "react-native": "^0.76",
    "react-native-builder-bob": "^0.43.0",
    "typescript": "^5.7",
    "vitest": "^4.1.10"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "**/*.test.*",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
